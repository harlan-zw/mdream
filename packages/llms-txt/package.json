{
  "name": "@mdream/llms-txt",
  "type": "module",
  "version": "0.17.0",
  "description": "Engine-agnostic llms.txt artifact generator. Assembles llms.txt, llms-full.txt, and individual markdown files from pre-converted content.",
  "author": {
    "name": "Harlan Wilton",
    "email": "harlan@harlanzw.com",
    "url": "https://harlanzw.com/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harlan-zw/mdream",
    "directory": "packages/llms-txt"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "typecheck": "tsc --noEmit",
    "dev:prepare": "obuild --stub",
    "test": "vitest test",
    "test:attw": "attw --pack",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "pathe": "catalog:",
    "tinyglobby": "catalog:"
  }
}
