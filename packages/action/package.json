{
  "name": "@mdream/action",
  "type": "module",
  "version": "1.0.7",
  "description": "GitHub Action for mdream llms.txt generation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harlan-zw/mdream",
    "directory": "packages/action"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "dev:prepare": "echo 'Action dev:prepare: using build output'",
    "test:attw": "echo 'No package types to test for action bundle'",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@actions/core": "catalog:",
    "@actions/exec": "catalog:",
    "@mdream/js": "workspace:*",
    "mdream": "workspace:*",
    "tinyglobby": "catalog:"
  },
  "devDependencies": {
    "@vercel/ncc": "catalog:",
    "typescript": "catalog:"
  }
}
