{
  "name": "@mdream/crawl",
  "type": "module",
  "version": "1.0.0-beta.11",
  "description": "Mdream Crawl generates comprehensive llms.txt artifacts from a single URL, using mdream to convert HTML to Markdown.",
  "author": {
    "name": "Harlan Wilton",
    "email": "harlan@harlanzw.com",
    "url": "https://harlanzw.com/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harlan-zw/mdream",
    "directory": "packages/crawl"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "import": {
        "types": "./dist/cli.d.mts",
        "default": "./dist/cli.mjs"
      },
      "default": "./dist/cli.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "@mdream/crawl": "./bin/mdream-crawl.mjs"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "obuild",
    "typecheck": "tsc --noEmit",
    "dev:prepare": "obuild --stub",
    "test": "vitest test",
    "test:attw": "attw --pack",
    "prepack": "pnpm run build"
  },
  "peerDependencies": {
    "crawlee": "^3.16.0",
    "playwright": "^1.53.2"
  },
  "peerDependenciesMeta": {
    "crawlee": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@mdream/js": "workspace:*",
    "mdream": "workspace:*",
    "nypm": "catalog:",
    "ofetch": "catalog:",
    "pathe": "catalog:",
    "picomatch": "catalog:",
    "ufo": "catalog:"
  },
  "devDependencies": {
    "@types/picomatch": "catalog:"
  }
}
