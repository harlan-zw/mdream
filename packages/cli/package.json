{
  "name": "@mdream/cli",
  "type": "module",
  "version": "0.17.0",
  "description": "CLI for mdream - convert HTML to Markdown from the command line.",
  "author": {
    "name": "Harlan Wilton",
    "email": "harlan@harlanzw.com",
    "url": "https://harlanzw.com/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harlan-zw/mdream",
    "directory": "packages/cli"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": {
